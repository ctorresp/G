FROM maven:3.9.9-eclipse-temurin-17-alpine AS build
WORKDIR /app
COPY settings.xml /root/.m2/
COPY pom.xml .
COPY src/ src/
RUN mvn package -B

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/target/reasignacion-service.jar app.jar
EXPOSE 8083
ENTRYPOINT ["java", "-jar", "app.jar"]
