{
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot-RedNorteApplication<auth-service>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "cl.duoc.rednorte.RedNorteApplication",
            "projectName": "auth-service",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Containers: Node.js Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-run: debug",
            "platform": "node",
            "node": {
                "package": "${workspaceFolder}/Frontend/package.json",
                "localRoot": "${workspaceFolder}/Frontend"
            }
        }
    ]
}